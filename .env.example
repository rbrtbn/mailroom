FASTMAIL_TOKEN=<your-fastmail-token>
DEEPL_API_KEY=<your-deepl-api-key>
RESEND_API_KEY=<your-resend-api-key>
PUSHOVER_USER_KEY=<your-pushover-user-key>
PUSHOVER_APP_TOKEN=<your-pushover-app-token>

# Auth bypass — set to "true" for local dev only. In production, configure
# POLICY_AUD and CF_TEAM_DOMAIN instead. Without any auth config the worker
# refuses to serve requests.
AUTH_BYPASS=true
