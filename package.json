{
	"name": "mailroom",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"setup": "scripts/setup.sh",
		"dev": "scripts/dev.sh --test-scheduled",
		"build": "pnpm generate-types && pnpm tsc",
		"push-secrets": "scripts/push-secrets.sh",
		"deploy": "wrangler deploy",
		"deploy:dry": "wrangler deploy --dry-run",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"test:coverage": "vitest run --coverage --project unit",
		"generate-types": "wrangler types",
		"typecheck": "pnpm tsc --noEmit",
		"format": "prettier --write src test",
		"lint": "eslint src test",
		"lint:fix": "eslint src test --fix",
		"prepare": "husky"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.14",
		"@eslint/js": "^10",
		"@types/node": "^25.3.0",
		"@vitest/coverage-v8": "3.2.4",
		"eslint": "^10",
		"eslint-plugin-functional": "^9.0.2",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"eslint-plugin-unused-imports": "^4.4.1",
		"husky": "^9.1.7",
		"jiti": "^2.6.1",
		"lint-staged": "^16.2.7",
		"prettier": "^3.8.1",
		"type-fest": "^5.4.4",
		"typescript": "^5.5.2",
		"typescript-eslint": "^8.56.0",
		"vitest": "~3.2.4",
		"wrangler": "^4.67.0"
	},
	"dependencies": {
		"jose": "^6.1.3",
		"neverthrow": "^8.2.0",
		"ts-pattern": "^5.9.0",
		"zod": "^4.3.6"
	},
	"lint-staged": {
		"*.ts": [
			"prettier --write",
			"eslint"
		],
		"*.{json,md,toml,jsonc}": [
			"prettier --write"
		]
	},
	"pnpm": {
		"overrides": {
			"@typescript-eslint/typescript-estree>minimatch": "^10.2.1",
			"glob>minimatch": "^10.2.1"
		}
	}
}
