{
	"name": "mailroom",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev --test-scheduled",
		"start": "wrangler dev --test-scheduled",
		"cf-typegen": "wrangler types",
		"test": "vitest run",
		"lint": "eslint src test",
		"typecheck": "tsc --noEmit",
		"prepare": "husky"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.14",
		"@eslint/js": "^9.39.3",
		"@types/node": "^25.3.0",
		"eslint": "^9",
		"eslint-plugin-functional": "^9.0.2",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"eslint-plugin-unused-imports": "^4.4.1",
		"husky": "^9.1.7",
		"jiti": "^2.6.1",
		"lint-staged": "^16.2.7",
		"prettier": "^3.8.1",
		"typescript": "^5.5.2",
		"typescript-eslint": "^8.56.0",
		"vitest": "^3.2.4",
		"wrangler": "^4.67.0"
	},
	"dependencies": {
		"neverthrow": "^8.2.0",
		"ts-pattern": "^5.9.0",
		"zod": "^4.3.6"
	},
	"lint-staged": {
		"*.ts": [
			"prettier --write",
			"eslint"
		],
		"*.{json,md,toml,jsonc}": [
			"prettier --write"
		]
	}
}
